{
  "name": "idorendmaker-desktop",
  "productName": "idorendmaker-desktop",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "npm run build:backend && electron-forge package",
    "make": "npm run build:backend && electron-forge make",
    "publish": "npm run build:backend && electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "build:backend": "cd ../idorendmaker-backend && mvn -Pnative native:compile-no-fork",
    "build:backend:dev": "cd ../idorendmaker-backend && mvn -Pnative native:compile-no-fork -Dquarkus.native.debug.enabled=true",
    "check:backend": "test -f ../idorendmaker-backend/target/idorendmaker-backend.exe && echo 'Backend executable found' || echo 'Backend executable missing - run npm run build:backend'",
    "populate-db": "tsx scripts/populate-db.ts",
    "migrate-locking": "tsx scripts/migrate-schedule-locking.ts"
  },
  "keywords": [],
  "author": {
    "name": "Szabolcs",
    "email": "your-email@domain.com"
  },
  "license": "MIT",
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.429.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "react-router-dom": "^6.26.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron-forge/plugin-vite": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^22.4.1",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "31.3.1",
    "electron-forge-maker-nsis": "^26.0.18",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "~4.5.4",
    "vite": "^5.4.2"
  }
}