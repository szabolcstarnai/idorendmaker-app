{
  "name": "idorendmaker-desktop",
  "productName": "Időrend Készítő",
  "version": "2025.9.1",
  "description": "Kajak-kenu verseny időrend készítő alkalmazás",
  "main": ".vite/build/main.js",
  "scripts": {
    "postinstall": "electron-rebuild",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "build:backend": "cd ../idorendmaker-backend && mvn -Pnative native:compile-no-fork",
    "build:backend:dev": "cd ../idorendmaker-backend && mvn -Pnative native:compile-no-fork -Dquarkus.native.debug.enabled=true",
    "build:pdfprocessor": "cd ../idorendmaker-pdfprocessor && mvn -DskipTests package",
    "copy:resources": "cp ../idorendmaker-backend/target/idorendmaker-backend.exe resources/ && cp ../idorendmaker-pdfprocessor/target/idorendmaker-pdfprocessor-*.jar resources/idorendmaker-pdfprocessor.jar && echo 'Resources copied to installer directory'",
    "check:pdfprocessor": "test -f ../idorendmaker-pdfprocessor/target/idorendmaker-pdfprocessor-*.jar && echo 'PDF processor JAR found' || echo 'PDF processor JAR missing - run npm run build:pdfprocessor'",
    "build:all": "npm run build:backend && npm run build:pdfprocessor",
    "check:backend": "test -f ../idorendmaker-backend/target/idorendmaker-backend.exe && echo 'Backend executable found' || echo 'Backend executable missing - run npm run build:backend'",
    "check:resources": "npm run check:backend && npm run check:pdfprocessor && test -f resources/idorendmaker-production.db && echo 'All resources ready for installer' || echo 'Some resources missing - check above'",
    "make:installer": "npm run check:resources && npm run make",
    "beforePack": "./script/beforePack.js"
  },
  "keywords": [],
  "author": {
    "name": "Szabolcs Tárnai",
    "email": "tarnai.szabolcs01@gmail.com"
  },
  "license": "MIT",
  "build": {
    "appId": "hu.szabolcst.idorendmaker",
    "productName": "Időrend készítő",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      ".vite/**",
      "resources/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/idorendmaker-backend.exe",
        "to": "idorendmaker-backend.exe"
      },
      {
        "from": "resources/idorendmaker-pdfprocessor.jar",
        "to": "idorendmaker-pdfprocessor.jar"
      },
      {
        "from": "resources/idorendmaker-production.db",
        "to": "idorendmaker-production.db"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "include": "build/installer/installer.nsh",
      "warningsAsErrors": false
    },
    "win": {
      "icon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.3",
    "@electron-forge/maker-deb": "^7.8.3",
    "@electron-forge/maker-rpm": "^7.8.3",
    "@electron-forge/maker-squirrel": "^7.8.3",
    "@electron-forge/maker-zip": "^7.8.3",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.3",
    "@electron-forge/plugin-fuses": "^7.8.3",
    "@electron-forge/plugin-vite": "^7.8.3",
    "@electron/fuses": "^1.8.0",
    "@felixrieseberg/electron-forge-maker-nsis": "^7.2.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "electron": "37.3.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "rcedit": "^4.0.1",
    "tsx": "^4.20.4",
    "typescript": "~5.3.0",
    "vite": "^5.4.19"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "autoprefixer": "^10.4.21",
    "axios": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "diacritics": "^1.3.0",
    "electron-squirrel-startup": "^1.0.1",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.1",
    "lucide-react": "^0.539.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  }
}