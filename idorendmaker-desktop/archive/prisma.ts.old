import { PrismaClient } from '@prisma/client'
import * as path from 'path'

// Create a global instance of PrismaClient for Electron app
let client: PrismaClient

const getPrismaClient = (): PrismaClient => {
  if (!client) {
    // Override the database URL to use the correct path in Electron
    const dbPath = path.join(process.cwd(), 'idorendmaker.db')
    const databaseUrl = `file:${dbPath}`
    
    client = new PrismaClient({
      datasources: {
        db: {
          url: databaseUrl,
        },
      },
    })

    console.log('✅ Prisma client initialized with database at:', dbPath)
  }
  
  return client
}

// Export the client instance
export const prisma = getPrismaClient()

// Function to close the Prisma client (for cleanup)
export const closePrismaClient = async (): Promise<void> => {
  if (client) {
    await client.$disconnect()
    console.log('✅ Prisma client disconnected')
  }
}

export default prisma