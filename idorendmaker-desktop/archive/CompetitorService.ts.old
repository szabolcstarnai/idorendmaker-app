// import { prisma } from '../../../data/services/prisma'
import { BackendAPIService } from '../src/data/services/BackendAPIService'
import { CompetitorSchedule, CompetitorRaceDetails, ScheduleRace } from '../shared/types/race'

export class CompetitorService {
  /**
   * Analyze competitor schedules from a set of schedule races
   * 
   * MIGRATED TO BACKEND: All complex logic moved to CompetitorServiceImpl.analyzeCompetitorSchedules()
   * This method now makes a simple HTTP request to the Spring Boot backend
   */
  static async analyzeCompetitorSchedules(
    scheduleRaces: ScheduleRace[], 
    pdfExtractionId?: number
  ): Promise<CompetitorSchedule[]> {
    // Use backend HTTP API instead of direct Prisma queries
    return await BackendAPIService.analyzeCompetitorSchedules(scheduleRaces, pdfExtractionId)

    /* ORIGINAL PRISMA IMPLEMENTATION (KEPT FOR REFERENCE):
    
    if (!pdfExtractionId) {
      return [] // No competitor data available
    }

    try {
      // Get competitor data for this PDF extraction
      const competitors = await prisma.competitorEntry.findMany({
        where: { pdfExtractionId },
        include: {
          raceCompetitorAssociations: {
            include: { race: true }
          }
        }
      })

      const competitorSchedules: CompetitorSchedule[] = []

      for (const competitor of competitors) {
        // Find races this competitor is entered in from the current schedule
        const allCompetitorRaces = scheduleRaces.filter(scheduleRace =>
          competitor.raceCompetitorAssociations.some(assoc => assoc.raceId === scheduleRace.race.id)
        )

        if (allCompetitorRaces.length === 0) continue

        // Apply "worst case scenario" logic for multiple heats:
        // Problem: Competitors enter ONE heat per level (e.g., either "I. Előfutam" OR "II. Előfutam"), 
        //          but the system was treating them as being in ALL heats, creating false conflicts.
        // Solution: 1. Group races by (race.id, level.levelType) to identify multiple heats of same level
        //           2. For each group with multiple heats, assume competitor is in the heat that 
        //              creates the WORST possible scheduling conflict with other races
        //           3. This ensures conservative safety margins while eliminating false positives
        const raceGroups = this.groupScheduleRacesByRaceAndLevel(allCompetitorRaces)
        const competitorRaces = this.selectWorstCaseHeats(raceGroups, scheduleRaces)

        // Sort races by scheduled time
        competitorRaces.sort((a, b) => a.startTime.localeCompare(b.startTime))

        // Calculate race details with intervals
        const raceDetails: CompetitorRaceDetails[] = competitorRaces.map((race, index) => {
          const nextRace = competitorRaces[index + 1]
          
          let intervalToNext: number | undefined
          let recoveryTime: number | undefined
          
          if (nextRace) {
            intervalToNext = this.calculateMinutesBetween(race.startTime, nextRace.startTime)
            // Assume 5 minutes average race duration for recovery calculation
            recoveryTime = intervalToNext - 5
          }

          // Determine conflict level based on recovery time
          let conflictLevel: 'none' | 'warning' | 'critical' = 'none'
          if (recoveryTime !== undefined) {
            if (recoveryTime < 30) {
              conflictLevel = 'critical'
            } else if (recoveryTime < 60) {
              conflictLevel = 'warning'
            }
          }

          return {
            raceId: race.race.id,
            raceName: race.race.name,
            scheduledTime: race.startTime,
            estimatedDuration: 5, // Placeholder: 5 minutes average
            intervalToNext,
            recoveryTime,
            conflictLevel
          }
        })

        // Calculate overall statistics
        const intervals = raceDetails
          .map(r => r.intervalToNext)
          .filter((interval): interval is number => interval !== undefined)

        const shortestInterval = intervals.length > 0 ? Math.min(...intervals) : null
        const longestInterval = intervals.length > 0 ? Math.max(...intervals) : null

        // Determine risk level
        let riskLevel: 'low' | 'medium' | 'high' = 'low'
        const criticalCount = raceDetails.filter(r => r.conflictLevel === 'critical').length
        const warningCount = raceDetails.filter(r => r.conflictLevel === 'warning').length

        if (criticalCount > 0) {
          riskLevel = 'high'
        } else if (warningCount > 0) {
          riskLevel = 'medium'
        }

        competitorSchedules.push({
          competitorId: competitor.competitorId,
          competitorName: competitor.competitorName,
          organization: competitor.organization,
          birthYear: competitor.birthYear,
          races: raceDetails,
          totalRaces: raceDetails.length,
          shortestInterval,
          longestInterval,
          riskLevel
        })
      }

      // Sort by risk level and total races (high risk first, then most races)
      competitorSchedules.sort((a, b) => {
        const riskOrder = { high: 3, medium: 2, low: 1 }
        const riskDiff = riskOrder[b.riskLevel] - riskOrder[a.riskLevel]
        if (riskDiff !== 0) return riskDiff
        return b.totalRaces - a.totalRaces
      })

      console.log(`Analyzed ${competitorSchedules.length} competitor schedules`)
      return competitorSchedules
    } catch (error) {
      console.error('Error analyzing competitor schedules:', error)
      return []
    }
    
    */
  }

