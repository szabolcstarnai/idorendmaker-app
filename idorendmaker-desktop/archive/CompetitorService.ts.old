  /**
   * Group ScheduleRaces by race and level type to handle multiple heats
   */
  private static groupScheduleRacesByRaceAndLevel(scheduleRaces: ScheduleRace[]): Map<string, ScheduleRace[]> {
    const groups = new Map<string, ScheduleRace[]>()
    
    for (const scheduleRace of scheduleRaces) {
      const key = `${scheduleRace.race.id}-${scheduleRace.level.levelType}`
      if (!groups.has(key)) {
        groups.set(key, [])
      }
      groups.get(key)!.push(scheduleRace)
    }
    
    return groups
  }

  /**
   * Select worst-case heats from groups for conflict checking
   * For groups with multiple heats, choose the heat that creates worst possible conflicts
   */
  private static selectWorstCaseHeats(
    raceGroups: Map<string, ScheduleRace[]>, 
    allScheduleRaces: ScheduleRace[]
  ): ScheduleRace[] {
    const selectedHeats: ScheduleRace[] = []
    
    for (const [, heats] of raceGroups) {
      if (heats.length === 1) {
        // Only one heat, use it
        selectedHeats.push(heats[0])
        continue
      }
      
      // Multiple heats - select worst case for conflict checking
      // Sort heats by start time
      const sortedHeats = heats.sort((a, b) => a.startTime.localeCompare(b.startTime))
      
      // Find races from OTHER groups to check conflicts against
      const otherRaces = allScheduleRaces.filter(race => 
        !heats.some(heat => heat.id === race.id)
      )
      
      if (otherRaces.length === 0) {
        // No other races to conflict with, just pick first heat
        selectedHeats.push(sortedHeats[0])
        continue
      }
      
      // Find the heat that creates the worst (shortest) recovery time
      let worstHeat = sortedHeats[0]
      let worstRecoveryTime = Infinity
      
      for (const heat of sortedHeats) {
        // Check conflicts with races before and after
        const conflictBefore = this.findClosestRaceBefore(heat, otherRaces)
        const conflictAfter = this.findClosestRaceAfter(heat, otherRaces)
        
        let minRecoveryTime = Infinity
        
        if (conflictBefore) {
          const timeBefore = this.calculateMinutesBetween(conflictBefore.startTime, heat.startTime) - 5 // 5min race duration
          minRecoveryTime = Math.min(minRecoveryTime, timeBefore)
        }
        
        if (conflictAfter) {
          const timeAfter = this.calculateMinutesBetween(heat.startTime, conflictAfter.startTime) - 5 // 5min race duration  
          minRecoveryTime = Math.min(minRecoveryTime, timeAfter)
        }
        
        // Select the heat with the worst (shortest) recovery time
        if (minRecoveryTime < worstRecoveryTime) {
          worstRecoveryTime = minRecoveryTime
          worstHeat = heat
        }
      }
      
      selectedHeats.push(worstHeat)
    }
    
    return selectedHeats
  }

  /**
   * Find the closest race before the given race
   */
  private static findClosestRaceBefore(targetRace: ScheduleRace, otherRaces: ScheduleRace[]): ScheduleRace | null {
    const racesBefore = otherRaces.filter(race => race.startTime < targetRace.startTime)
    if (racesBefore.length === 0) return null
    
    return racesBefore.reduce((closest, race) => 
      race.startTime > closest.startTime ? race : closest
    )
  }

  /**
   * Find the closest race after the given race  
   */
  private static findClosestRaceAfter(targetRace: ScheduleRace, otherRaces: ScheduleRace[]): ScheduleRace | null {
    const racesAfter = otherRaces.filter(race => race.startTime > targetRace.startTime)
    if (racesAfter.length === 0) return null
    
    return racesAfter.reduce((closest, race) => 
      race.startTime < closest.startTime ? race : closest
    )
  }

  /**
   * Calculate minutes between two time strings (HH:MM format)
   */
  private static calculateMinutesBetween(startTime: string, endTime: string): number {
    const [startHours, startMinutes] = startTime.split(':').map(Number)
    const [endHours, endMinutes] = endTime.split(':').map(Number)
    
    const startTotalMinutes = startHours * 60 + startMinutes
    const endTotalMinutes = endHours * 60 + endMinutes
    
    return endTotalMinutes - startTotalMinutes
  }

